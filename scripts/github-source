#!/usr/bin/env bash
# Generate the local GitHub migration source URL from the CI/local token.

set -eo pipefail

repository_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
readonly repository_root
output_file="${repository_root}/test/secrets/github"
readonly output_file
token="${MIGRIEREN_GITHUB_TOKEN:-}"
readonly token

if [[ -z "$token" ]]; then
  printf '%s\n' 'MIGRIEREN_GITHUB_TOKEN must be set' >&2
  exit 1
fi

case "$token" in
  *[!A-Za-z0-9_-]*)
    printf '%s\n' 'MIGRIEREN_GITHUB_TOKEN contains unsupported URL characters' >&2
    exit 1
    ;;
esac

umask 077
temporary_file="$(mktemp "${output_file}.XXXXXX")"
trap 'rm -f "$temporary_file"' EXIT

printf 'github://token:%s@alexfalkowski/app-config/test/migrations\n' "$token" > "$temporary_file"
mv -f "$temporary_file" "$output_file"
trap - EXIT
